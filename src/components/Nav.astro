---
import InteractiveNav from './InteractiveNav.astro';
import { navLinks } from '../data/site';
---

<nav class="fixed top-0 w-full z-50 border-b border-dark-border bg-dark-bg/40 backdrop-blur-xl isolate" aria-label="Main navigation">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16 sm:h-20">

      <!-- Logo -->
      <a href="/" class="flex shrink-0 items-center" aria-label="Rydal home">
        <img
          src="/app_logo_white.png"
          alt="Rydal — riding assistant and riders companion app"
          class="h-12 sm:h-14 md:h-16 w-auto object-contain"
          width="160"
          height="64"
        />
      </a>

      <!-- Desktop nav -->
      <div class="hidden md:flex items-center space-x-8 uppercase text-xs font-bold tracking-widest text-dark-text-secondary">
        {navLinks.map((link) => (
          <a href={link.href} class="hover:text-hero-accent transition-colors">
            {link.name}
          </a>
        ))}
        <a
          href="#waitlist"
          id="nav-cta"
          class="px-6 py-2 bg-hero-accent text-white hover:bg-opacity-90 transition-all rounded-sm uppercase tracking-tighter italic font-black shadow-[0_0_20px_rgba(47,107,255,0.3)] hover:shadow-[0_0_30px_rgba(47,107,255,0.5)]"
        >
          Join Beta
        </a>
      </div>

      <!-- Mobile hamburger (InteractiveNav handles this) -->
      <InteractiveNav />
    </div>
  </div>
</nav>
