---
import Icon from '../Icon.astro';
import { voiceFeatures } from '../../data/site';
---

<section id="dashboard" class="py-32 border-y border-dark-border bg-dark-surface/50 relative">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
      <div>
        <span class="text-hero-accent font-mono text-xs tracking-widest uppercase mb-4 block">// Hands-Free Command</span>
        <h2 class="text-4xl md:text-6xl font-black italic tracking-tighter uppercase mb-8 leading-tight">
          Focus on the road, <br />
          <span class="text-white opacity-40">not the screen.</span>
        </h2>
        <ul class="space-y-6">
          {voiceFeatures.map((item) => (
            <li class="flex items-start gap-4 group">
              <Icon name="chevron-right" size={20} class="w-5 h-5 text-hero-accent group-hover:translate-x-1 transition-transform shrink-0 mt-0.5" />
              <span class="text-lg text-dark-text-secondary font-medium tracking-wide">{item}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="relative">
        <div class="aspect-square glass-panel rounded-full flex items-center justify-center relative p-12 border-2 border-hero-accent/40 shadow-[0_0_50px_rgba(47,107,255,0.1)]">
          <div class="w-full h-full rounded-full border border-dark-border border-dashed animate-spin-slow absolute inset-4" aria-hidden="true"></div>
          <div class="text-center z-10">
            <div class="w-24 h-24 bg-hero-accent rounded-full mx-auto mb-8 flex items-center justify-center shadow-[0_0_30px_rgba(47,107,255,0.5)] animate-pulse-mic">
              <Icon name="mic" size={40} class="w-10 h-10 text-white" />
            </div>
            <div class="font-mono text-hero-accent text-sm tracking-[0.2em] mb-2">LISTENING</div>
            <p class="text-xl font-bold uppercase tracking-widest text-white italic">"Find nearest shell station"</p>
          </div>
        </div>

        <div class="absolute -top-4 -right-4 glass-panel px-4 py-2 rounded-sm text-[10px] uppercase tracking-widest font-bold">Latency: 24ms</div>
        <div class="absolute -bottom-4 -left-4 glass-panel px-4 py-2 rounded-sm text-[10px] uppercase tracking-widest font-bold">Model: Rydal-V1</div>
      </div>
    </div>
  </div>
</section>
