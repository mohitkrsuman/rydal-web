    </svg>
  )
}
{
  name === 'chevron-right' && (
    <svg xmlns="http://www.w3.org/2000/svg" width={size} height={size} class={className} fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
