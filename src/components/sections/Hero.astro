<style>
  @keyframes slide-in-1 {
    from {
      transform: translateY(110%);
      opacity: 0;
    }
    to {
      transform: translateY(0);
      opacity: 1;
    }
  }
  @keyframes slide-in-2 {
    from {
      transform: translateY(110%);
      opacity: 0;
    }
    to {
      transform: translateY(0);
      opacity: 1;
    }
  }
  @keyframes slide-in-3 {
    from {
      transform: translateY(110%);
      opacity: 0;
    }
    to {
      transform: translateY(0);
      opacity: 1;
    }
  }
  @keyframes slide-in-4 {
    from {
      transform: translateY(110%);
      opacity: 0;
    }
    to {
      transform: translateY(0);
      opacity: 1;
    }
  }
  .animate-slide-in-1 {
    animation: slide-in-1 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.1s both;
  }
  .animate-slide-in-2 {
    animation: slide-in-2 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.25s both;
  }
  .animate-slide-in-3 {
    animation: slide-in-3 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.4s both;
  }
  .animate-slide-in-4 {
    animation: slide-in-4 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.55s both;
  }

  /* Extra small screens */
  @media (max-width: 400px) {
    .xs\:flex-row {
      flex-direction: row;
    }
    .xs\:block {
      display: block;
    }
  }
</style>

<script>
  // Parallax effect on the bike wrapper following mouse (desktop only)
  const bikeWrapper = document.getElementById("bike-parallax-wrapper");
  const heroBike = document.getElementById("hero-bike");
  if (
    bikeWrapper &&
    heroBike &&
    window.matchMedia("(min-width: 1024px)").matches
  ) {
    document.addEventListener("mousemove", (e) => {
      const { innerWidth, innerHeight } = window;
      const dx = (e.clientX / innerWidth - 0.5) * 20;
      const dy = (e.clientY / innerHeight - 0.5) * 10;
      bikeWrapper.style.transform = `translate(${dx * 0.6}px, ${dy * 0.4}px)`;
    });
  }

  // Hero scroll parallax (speed lines fade out as you scroll)
  window.addEventListener("scroll", () => {
    const scrollY = window.scrollY;
    const heroEl = document.getElementById("hero");
    if (!heroEl) return;
    heroEl.querySelectorAll(".speed-line").forEach((line) => {
      (line as HTMLElement).style.opacity = String(
        Math.max(0, 1 - scrollY * 0.003),
      );
    });
    // Subtle parallax on bike (only on desktop)
    if (heroBike && window.matchMedia("(min-width: 640px)").matches) {
      (heroBike as HTMLElement).style.transform =
        `translateY(${scrollY * 0.08}px)`;
    }
  });
</script>
