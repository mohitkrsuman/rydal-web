---
import Icon from '../Icon.astro';
---

<section id="waitlist" class="py-16 sm:py-24 lg:py-32 bg-dark-bg relative overflow-hidden">

  <!-- Large radial glow -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[300px] sm:w-[600px] h-[300px] sm:h-[600px] rounded-full bg-hero-accent/8 blur-[120px]"></div>
  </div>

  <!-- Speed line decoration -->
  <div class="speed-lines" aria-hidden="true">
    <div class="speed-line" style="--top: 20%; --duration: 4s; --delay: 0s;"></div>
    <div class="speed-line" style="--top: 75%; --duration: 3.5s; --delay: 1.5s;"></div>
  </div>

  <!-- Grid overlay -->
  <div class="absolute inset-0 grid-overlay opacity-30 pointer-events-none" aria-hidden="true"></div>

  <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center relative z-10">

    <!-- Zap icon -->
    <div class="inline-block p-3 sm:p-4 bg-hero-accent/10 rounded-2xl mb-6 sm:mb-8 reveal-scale border border-hero-accent/20 shadow-[0_0_30px_rgba(47,107,255,0.2)]">
      <Icon name="zap" size={32} class="w-8 h-8 sm:w-10 sm:h-10 text-hero-accent animate-pulse-mic" />
    </div>

    <!-- Heading -->
    <h2 class="text-3xl sm:text-4xl md:text-4xl lg:text-5xl xl:text-5xl font-black italic tracking-tighter uppercase mb-4 sm:mb-6 leading-none reveal" style="transition-delay:100ms">
      Claim Your Spot <br />in the Pack
    </h2>
    <p class="text-base sm:text-xl text-dark-text-secondary mb-8 sm:mb-12 uppercase tracking-wide font-bold reveal" style="transition-delay:250ms">
      Be the first to experience the Rydal ecosystem.
    </p>

    <!-- Waitlist form (Native Astro + Vanilla JS) -->
    <div class="reveal relative" style="transition-delay:400ms">
      
      <!-- Hidden iframe to prevent page redirect on submit -->
      <iframe name="hidden_iframe" id="hidden_iframe" style="display:none;" onload="if(window.submitted) { document.getElementById('waitlist-form-container').style.display='none'; document.getElementById('waitlist-success').style.display='flex'; }"></iframe>

      <!-- Success Message (Hidden by default) -->
      <div id="waitlist-success" class="p-12 glass-panel border-success/30 rounded-lg flex-col items-center hidden" style="display: none;">
        <div class="w-20 h-20 bg-success/20 rounded-full flex items-center justify-center mb-6">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-success" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" /></svg>
        </div>
        <h3 class="text-3xl font-black italic uppercase mb-4 tracking-tighter text-white">Welcome aboard, Rider.</h3>
        <p class="text-dark-text-secondary italic tracking-widest font-bold uppercase text-sm">You are officially on the list. High-five.</p>
      </div>

      <!-- Form Container -->
      <div id="waitlist-form-container">
        <form 
          action="https://docs.google.com/forms/d/e/1FAIpQLSfksf_Z4wD-uweTlIyAhp5mOjNoJUpIZ9IOcRh12rq4lU6fQw/formResponse" 
          method="post" 
          target="hidden_iframe" 
          onsubmit="window.submitted=true; document.getElementById('submit-btn-text').style.display='none'; document.getElementById('submit-btn-processing').style.display='inline-flex'; document.getElementById('submit-btn').disabled=true;"
          class="space-y-3 sm:space-y-4"
        >
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-4">
            <input
              required
              type="text"
              name="entry.777409729"
              placeholder="YOUR NAME"
              class="w-full bg-dark-surface border border-dark-border px-4 sm:px-6 py-4 sm:py-5 focus:border-hero-accent outline-none transition-colors font-black italic uppercase tracking-widest text-white text-sm sm:text-base"
            />
            <input
              required
              type="email"
              name="entry.2061601030"
              placeholder="EMAIL ADDRESS"
              class="w-full bg-dark-surface border border-dark-border px-4 sm:px-6 py-4 sm:py-5 focus:border-hero-accent outline-none transition-colors font-black italic uppercase tracking-widest text-white text-sm sm:text-base"
            />
          </div>
          <select 
            name="entry.1472215364" 
            required 
            class="w-full bg-dark-surface border border-dark-border px-4 sm:px-6 py-4 sm:py-5 focus:border-hero-accent outline-none transition-colors font-black italic uppercase tracking-widest text-white appearance-none text-sm sm:text-base"
          >
            <option value="">SELECT YOUR MACHINE</option>
            <option value="Sport / Street">SPORT / STREET</option>
            <option value="ADV/ Dual sport">ADV / DUAL SPORT</option>
            <option value="Cruiser">CRUISER</option>
            <option value="Track / Race">TRACK / RACE</option>
            <option value="other / vintage">OTHER / VINTAGE</option>
          </select>
          <button
            type="submit"
            id="submit-btn"
            class="w-full py-4 sm:py-6 bg-hero-accent text-white font-black italic uppercase text-lg sm:text-2xl tracking-tighter hover:bg-opacity-90 disabled:opacity-50 transition-all flex items-center justify-center gap-3 sm:gap-4"
          >
            <span id="submit-btn-text" class="flex items-center gap-3 sm:gap-4">
              Request Beta Access
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 sm:w-6 sm:h-6 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
            </span>
            <span id="submit-btn-processing" style="display: none;">
              PROCESSING...
            </span>
          </button>
        </form>
      </div>
    </div>

    <!-- Social proof -->
    <div class="mt-8 sm:mt-10 flex items-center justify-center gap-4 sm:gap-6 flex-wrap reveal" style="transition-delay:600ms">
      <div class="flex -space-x-3">
        {[...Array(5)].map((_, i) => (
          <div
            class="w-7 h-7 sm:w-8 sm:h-8 rounded-full border-2 border-dark-bg flex items-center justify-center text-[10px] font-bold"
            style={`background: hsl(${220 + i * 15}, 60%, ${30 + i * 5}%);`}
          >
            {String.fromCodePoint(0x1F3CD + (i % 3))}
          </div>
        ))}
      </div>
      <p class="text-[9px] sm:text-[10px] text-dark-text-secondary uppercase tracking-[0.25em] sm:tracking-[0.3em] font-bold">
        Join 4,200+ riders waiting for the revolution
      </p>
    </div>

    <!-- Trust badges -->
    <div class="mt-6 sm:mt-8 flex items-center justify-center gap-4 sm:gap-8 flex-wrap reveal" style="transition-delay:750ms">
      <div class="flex items-center gap-1.5 sm:gap-2 text-[9px] sm:text-[10px] uppercase tracking-widest text-dark-text-secondary font-bold">
        <Icon name="shield" size={11} class="text-success shrink-0" />
        <span>No spam</span>
      </div>
      <div class="flex items-center gap-1.5 sm:gap-2 text-[9px] sm:text-[10px] uppercase tracking-widest text-dark-text-secondary font-bold">
        <Icon name="zap" size={11} class="text-hero-accent shrink-0" />
        <span>Early access</span>
      </div>
      <div class="flex items-center gap-1.5 sm:gap-2 text-[9px] sm:text-[10px] uppercase tracking-widest text-dark-text-secondary font-bold">
        <Icon name="award" size={11} class="text-warning shrink-0" />
        <span>Founding perks</span>
      </div>
    </div>
  </div>
</section>
