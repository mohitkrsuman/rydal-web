---
import Icon from "../Icon.astro";
---

<section
  class="relative pt-32 sm:pt-32 pb-28 sm:pb-20 overflow-hidden sm:min-h-screen flex items-center parallax-container"
  id="hero"
>
  <!-- Speed-line atmospheric overlay -->
  <div class="speed-lines" aria-hidden="true">
    <div class="speed-line" style="--top: 18%; --duration: 3.2s; --delay: 0s;">
    </div>
    <div
      class="speed-line"
      style="--top: 32%; --duration: 2.4s; --delay: 0.6s;"
    >
    </div>
    <div
      class="speed-line"
      style="--top: 48%; --duration: 3.8s; --delay: 1.2s;"
    >
    </div>
    <div
      class="speed-line"
      style="--top: 62%; --duration: 2.8s; --delay: 0.3s;"
    >
    </div>
    <div
      class="speed-line"
      style="--top: 74%; --duration: 3.5s; --delay: 0.9s;"
    >
    </div>
    <div
      class="speed-line"
      style="--top: 85%; --duration: 2.2s; --delay: 1.8s;"
    >
    </div>
  </div>

  <!-- Diagonal accent stripe (desktop only) -->
  <div
    class="absolute top-0 right-0 w-1/2 h-full opacity-[0.07] pointer-events-none overflow-hidden hidden lg:block"
    aria-hidden="true"
  >
    <div
      class="w-full h-full bg-gradient-to-bl from-hero-accent to-transparent rotate-12 -translate-y-20 translate-x-20"
    >
    </div>
  </div>

  <!-- Hero grid overlay -->
  <div
    class="absolute inset-0 grid-overlay opacity-50 pointer-events-none"
    aria-hidden="true"
  >
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 w-full">
    <div class="flex flex-col items-center gap-4 sm:gap-10">
      <!-- ─── Text content (always centered) ─── -->
      <div class="w-full max-w-2xl animate-fade-up text-left">
        <!-- Badge pill -->
        <div
          class="inline-flex items-center space-x-2 px-3 py-1 rounded-full border border-dark-border bg-dark-surface/50 text-hero-accent text-[9px] sm:text-[10px] font-bold tracking-widest uppercase mb-3 sm:mb-6"
        >
          <Icon name="zap" size={10} class="w-2.5 h-2.5 shrink-0" />
          <span>The riding assistant and riders companion for every rider</span>
        </div>

        <!-- Headline — 4 stacked lines, left-aligned -->
        <h1
          class="text-left text-5xl sm:text-6xl md:text-7xl lg:text-6xl xl:text-7xl font-black italic tracking-tighter leading-[0.92] mb-4 sm:mb-8 uppercase"
        >
          <span class="block overflow-hidden">
            <span class="block animate-slide-in-1">YOUR PACK.</span>
          </span>
          <span class="block overflow-hidden">
            <span
              class="block animate-slide-in-2 text-hero-accent text-outline-white"
              >SYNCED.</span
            >
          </span>
          <span class="block overflow-hidden">
            <span class="block animate-slide-in-3">YOUR RIDE.</span>
          </span>
          <span class="block overflow-hidden">
            <span class="block animate-slide-in-4">SECURED.</span>
          </span>
        </h1>

        <!-- Body text -->
        <p
          class="text-base text-left sm:text-lg md:text-xl text-dark-text-secondary max-w-xl mb-6 sm:mb-12 reveal"
          style="transition-delay:600ms"
        >
          Rydal is a riding companion for safe riding that transforms your
          smartphone into a dedicated motorcycle dashboard, with real-time group
          riding tracking and hands-free utility.
        </p>

        <!-- CTAs -->
        <div
          class="flex flex-nowrap gap-2 sm:gap-4 reveal justify-start"
          style="transition-delay:800ms"
        >
          <a
            href="#waitlist"
            id="hero-cta-waitlist"
            class="btn-neon whitespace-nowrap px-5 sm:px-10 py-3 sm:py-5 bg-hero-accent text-white font-black italic uppercase tracking-tighter text-sm sm:text-xl hover:scale-105 active:scale-95 transition-all text-center shadow-[0_0_30px_rgba(47,107,255,0.4)] hover:shadow-[0_0_60px_rgba(47,107,255,0.7)]"
          >
            Join the Waitlist
          </a>
          <a
            href="#features"
            id="hero-cta-features"
            class="whitespace-nowrap px-5 sm:px-10 py-3 sm:py-5 border border-dark-border hover:border-hero-accent/60 hover:bg-dark-surface text-white font-black italic uppercase tracking-tighter text-sm sm:text-xl transition-all text-center group"
          >
            <span class="group-hover:text-hero-accent transition-colors">Explore Features</span>
          </a>
        </div>

        <!-- Micro stats -->
        <div
          class="flex items-center justify-center gap-4 sm:gap-8 mt-6 sm:mt-12 reveal flex-wrap"
          style="transition-delay:1000ms"
        >
          <div class="flex flex-col items-center">
            <span class="text-xl sm:text-2xl font-black italic text-white"
              >4,200+</span
            >
            <span
              class="text-[9px] sm:text-[10px] uppercase tracking-widest text-dark-text-secondary"
              >Riders waiting</span
            >
          </div>
          <div class="w-px h-8 bg-dark-border hidden xs:block"></div>
          <div class="flex flex-col items-center">
            <span class="text-xl sm:text-2xl font-black italic text-hero-accent"
              >Real-time</span
            >
            <span
              class="text-[9px] sm:text-[10px] uppercase tracking-widest text-dark-text-secondary"
              >Group sync</span
            >
          </div>
          <div class="w-px h-8 bg-dark-border hidden xs:block"></div>
          <div class="flex flex-col items-center">
            <span class="text-xl sm:text-2xl font-black italic text-white"
              >AI-first</span
            >
            <span
              class="text-[9px] sm:text-[10px] uppercase tracking-widest text-dark-text-secondary"
              >Voice control</span
            >
          </div>
        </div>
      </div>

      <!-- ─── Motorcycle SVG (hidden on xs, centered below text on sm+) ─── -->
      <div
        class="relative w-full max-w-sm sm:max-w-md lg:max-w-lg mx-auto flex items-center justify-center hidden sm:flex"
        id="bike-parallax-wrapper"
        aria-hidden="true"
      >
        <!-- Radar rings -->
        <div
          class="absolute inset-0 flex items-center justify-center pointer-events-none"
        >
          <div
            class="absolute w-48 h-48 sm:w-64 sm:h-64 rounded-full border border-hero-accent/10 animate-radar"
            style="animation-delay:0s;"
          >
          </div>
          <div
            class="absolute w-48 h-48 sm:w-64 sm:h-64 rounded-full border border-hero-accent/10 animate-radar"
            style="animation-delay:1s;"
          >
          </div>
          <div
            class="absolute w-48 h-48 sm:w-64 sm:h-64 rounded-full border border-hero-accent/10 animate-radar"
            style="animation-delay:2s;"
          >
          </div>
        </div>

        <!-- Ground glow -->
        <div
          class="absolute bottom-8 left-1/2 -translate-x-1/2 w-48 sm:w-72 h-6 bg-hero-accent/20 blur-2xl rounded-full"
        >
        </div>

        <!-- Speed trail lines -->
        <div
          class="absolute left-0 top-1/2 -translate-y-1/2 flex flex-col gap-3 pointer-events-none"
        >
          <div
            class="h-px bg-gradient-to-r from-transparent via-hero-accent/50 to-transparent speed-trail"
            style="width:90px; animation-delay:0s;"
          >
          </div>
          <div
            class="h-px bg-gradient-to-r from-transparent via-hero-accent/30 to-transparent speed-trail"
            style="width:60px; animation-delay:0.3s;"
          >
          </div>
          <div
            class="h-px bg-gradient-to-r from-transparent via-hero-accent/40 to-transparent speed-trail"
            style="width:110px; animation-delay:0.6s;"
          >
          </div>
          <div
            class="h-px bg-gradient-to-r from-transparent via-hero-accent/20 to-transparent speed-trail"
            style="width:45px; animation-delay:0.9s;"
          >
          </div>
        </div>

        <!-- Motorcycle SVG -->
        <div
